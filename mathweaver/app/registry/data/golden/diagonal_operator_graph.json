      "symbols_used": ["A", "a_seq"], "local_assumptions": [],
      "source_refs": [], "source_level": "definition", "foundation_anchor_ids": [],
      "validation_status": "valid", "generated_by": "golden",
      "explanation": "三个控制对象之一。"
    },
    {

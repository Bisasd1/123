    {
      "id": "def_Ma", "context_id": "ctx_root", "node_type": "definition", "title": "定义 M_a",
      "statement_latex": "M_a x=(a_n x_n),\\qquad D(M_a)=\\{x\\in\\ell^2:(a_n x_n)\\in\\ell^2\\}",
      "statement_natural": "M_a 把每个坐标乘以 a_n,定义域取使像仍在 ℓ² 的最大集合。",
      "statement_canonical": {"claim_type": "set_equality", "subject": "D(M_a)", "defined_by": "maximal_domain"},
      "symbols_used": ["M_a", "a_seq", "l2"], "local_assumptions": [],
      "source_refs": ["DEF-multiplication-operator", "DEF-l2"], "source_level": "definition",
      "foundation_anchor_ids": ["DEF-multiplication-operator"],
      "validation_status": "valid", "generated_by": "golden",
      "explanation": "一切分析的起点:算子是对角的,所以每个坐标互相独立。"
    },
    {
      "id": "def_A", "context_id": "ctx_root", "node_type": "definition", "title": "定义 A",
      "statement_latex": "A=\\{a_n : n\\in\\mathbb N\\}",

{
  "id": "pythagorean_theorem",
  "name": "勾股定理(直角三角形)",
  "domain": "geometry",
  "keywords": [
    "勾股", "勾股定理", "毕达哥拉斯", "直角三角形", "斜边", "直角边",
    "a^2+b^2=c^2", "a²+b²=c²", "pythagorean", "right triangle"
  ],
  "required_objects": [
    {"name": "triangle", "latex": "\\triangle ABC", "kind": "triangle"},
    {"name": "a", "latex": "a", "kind": "length"},
    {"name": "b", "latex": "b", "kind": "length"},
    {"name": "c", "latex": "c", "kind": "length"}
  ],
  "template_symbols": [
    {"id": "tri_abc", "latex": "\\triangle ABC", "name": "三角形", "role": "triangle", "aliases": ["三角形ABC"]},
    {"id": "a", "latex": "a", "name": "一条直角边", "role": "leg", "aliases": ["AC", "x"]},
    {"id": "b", "latex": "b", "name": "另一条直角边", "role": "leg", "aliases": ["BC", "y"]},
    {"id": "c", "latex": "c", "name": "斜边", "role": "hypotenuse", "aliases": ["AB", "z"]},
    {"id": "S", "latex": "S", "name": "面积", "role": "area", "aliases": []}
  ],
  "skeleton": {
    "contexts": [
      {"id": "ctx_root", "assumptions": ["\\triangle ABC \\text{ 是直角三角形}", "\\angle C = 90^\\circ", "AC=b,\\ BC=a,\\ AB=c"]}
    ],
    "required_node_slots": [
      "setup_right_triangle",
      "build_square_area",
      "decompose_area",
      "equate_areas",
      "final_classification"
    ],
    "standard_obligations": []
  },
  "lint_rules": ["conclusion_traceability"],
  "common_pitfalls": [
    "把斜边和直角边符号写反,导致等式方向错误",
    "面积分解时漏掉系数 1/2",
    "从面积恒等式移项时符号出错"
  ],
  "unit_tests": [
    {"name": "3-4-5 三角形", "a": 3, "b": 4, "c": 5, "expected": "a^2+b^2=c^2"},
    {"name": "5-12-13 三角形", "a": 5, "b": 12, "c": 13, "expected": "a^2+b^2=c^2"},
    {"name": "8-15-17 三角形", "a": 8, "b": 15, "c": 17, "expected": "a^2+b^2=c^2"}
  ],
  "animation_paths": [
    {"id": "pythagorean_area_story", "name": "面积法证明勾股定理", "conclusion_slot": "final_classification"}
  ]
}

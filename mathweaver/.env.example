# ============ LLM(中转站,OpenAI 兼容协议)============
# 不配置则运行 demo 模式:对角算子谱分类题加载内置黄金图谱,全流程可演示
LLM_BASE_URL=https://your-relay.example.com/v1
LLM_API_KEY=sk-xxxxxxxx
# 建图等重任务用强模型;分类/润色可换便宜模型(默认同一个)
LLM_MODEL_HEAVY=claude-sonnet-4-5
LLM_MODEL_LIGHT=claude-sonnet-4-5
LLM_STREAM=true
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ============ 渲染 ============
RENDER_QUALITY=m        # l=480p(快) m=720p h=1080p
RENDER_TIMEOUT=600

# ============ 服务 ============
MW_HOST=127.0.0.1
MW_PORT=5000
